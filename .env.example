# ============================================================
# ROSHANAL GLOBAL — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# Insforge Backend (BaaS)
NEXT_PUBLIC_INSFORGE_URL=https://hhmgiq73.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Roshanal Global

# Geo & Currency API (free tiers, no key required)
NEXT_PUBLIC_GEO_API_URL=https://ipapi.co
NEXT_PUBLIC_EXCHANGE_RATE_API=https://open.er-api.com/v6/latest/NGN

# ============================================================
# OPTIONAL — Add these when you have the API keys
# ============================================================

# Payment Gateways
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxx
# PAYSTACK_SECRET_KEY=sk_live_xxx
# NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxx
# FLUTTERWAVE_SECRET_KEY=FLWSECK-xxx

# Google Services
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXX
# GOOGLE_MAPS_API_KEY=AIzaSyXXXX
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com

# Email / SMS
# SENDGRID_API_KEY=SG.xxxx
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business
# NEXT_PUBLIC_WHATSAPP_NUMBER=2348012345678

# Cloudinary (Image hosting)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=xxx
# CLOUDINARY_API_SECRET=xxx

# OpenAI (for AI features)
# OPENAI_API_KEY=sk-xxx
